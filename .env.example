# Application
# The public origin of the app (used for OAuth redirect URIs and client metadata)
NEXT_PUBLIC_APP_ORIGIN=http://127.0.0.1:8910

# Supabase (for OAuth session storage)
# Your Supabase project URL (safe to expose publicly)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth (ATProto)
# ES256 JWK private key set for signing OAuth client assertions.
# Generate with: bun run scripts/generate-jwk.ts
# Keep this secret — never commit the real value to git.
ATPROTO_JWK_PRIVATE='{"keys":[{"kty":"EC","crv":"P-256","x":"...","y":"...","d":"...","kid":"key-1","alg":"ES256"}]}'

# Session
# Secret used to encrypt the iron-session cookie (must be at least 32 characters)
COOKIE_SECRET=your-secret-key-at-least-32-characters-long
# Name of the session cookie set on the browser
COOKIE_NAME=greenglobe_session

# Existing vars (keep these)
# Mapbox public token for map rendering.
# The app supports either variable name.
NEXT_PUBLIC_MAPBOXGL_ACCESSTOKEN=
NEXT_PUBLIC_MAPBOX_API_KEY=
# Airtable API key for organization index
AIRTABLE_API_KEY=
# Airtable base ID for organization index
AIRTABLE_BASE_ID=
# Postgres connection string for ATProto auth mapping (non-pooling)
POSTGRES_URL_NON_POOLING_ATPROTO_AUTH_MAPPING=
# Password protecting the /invitecodes admin page
INVITE_CODES_PASSWORD=
# PDS admin credentials for invite code creation
PDS_ADMIN_IDENTIFIER=
PDS_ADMIN_PASSWORD=
# Google Cloud service account credentials JSON (for BigQuery access)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# GBIF Registry API - Automated Publishing
# Required for publishing datasets to GBIF programmatically
# GBIF account username (register at https://www.gbif.org/user/profile)
GBIF_USERNAME=
# GBIF account password — keep secret, never commit the real value
GBIF_PASSWORD=
# GBIF Registry API base URL
# UAT (test):        https://api.gbif-uat.org/v1  (default)
# Production:        https://api.gbif.org/v1
GBIF_API_URL=https://api.gbif-uat.org/v1
# GBIF organization UUID — GainForest's registered organization key
GBIF_ORG_KEY=c02486e8-eb54-4e94-81d8-1038cc58e208
# GBIF installation UUID — created once via scripts/bootstrap-gbif-installation.ts
# Leave blank until you have run the bootstrap script
GBIF_INSTALLATION_KEY=
