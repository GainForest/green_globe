{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["../src/*"]
    },
    "outDir": "../.e2e-dist",
    "rootDir": "..",
    "types": ["node"]
  },
  "include": [
    "fixtures/**/*.ts",
    "step-definitions/**/*.ts",
    "support/**/*.ts"
  ]
}
